# 9 "C:/Users/kostas.caplinskas/Documents/zephyrproject/zephyr/boards/st/nucleo_l432kc/arduino_nano_connector.dtsi" 2

/ {
 arduino_header: connector {
  compatible = "arduino-nano-header";
  #gpio-cells = <2>;
  gpio-map-mask = <0xffffffff 0xffffffc0>;
  gpio-map-pass-thru = <0 0x3f>;
  gpio-map = <0 0 &gpioa 10 0>,
      <1 0 &gpioa 9 0>,
      <2 0 &gpioa 12 0>,
      <3 0 &gpiob 0 0>,
      <4 0 &gpiob 7 0>,
      <5 0 &gpioa 6 0>,
      <6 0 &gpiob 1 0>,
      <7 0 &gpioc 14 0>,
      <8 0 &gpioc 15 0>,
      <9 0 &gpioa 8 0>,
      <10 0 &gpioa 11 0>,
      <11 0 &gpiob 5 0>,
      <12 0 &gpiob 4 0>,
      <13 0 &gpiob 3 0>,
      <14 0 &gpioa 0 0>,
      <15 0 &gpioa 1 0>,
      <16 0 &gpioa 3 0>,
      <19 0 &gpioa 4 0>,
      <18 0 &gpioa 5 0>,
      <19 0 &gpioa 6 0>,
      <20 0 &gpioa 7 0>,
      <21 0 &gpioa 2 0>;
 };
};

arduino_spi: &spi1 {};

arduino_serial: &usart1 {};

arduino_i2c: &i2c1 {};
# 11 "C:/Users/kostas.caplinskas/Documents/zephyrproject/zephyr/boards/st/nucleo_l432kc/nucleo_l432kc.dts" 2

/ {
 model = "STMicroelectronics STM32L432KC-NUCLEO board";
 compatible = "st,stm32l432kc-nucleo";

 chosen {
  zephyr,console = &usart2;
  zephyr,shell-uart = &usart2;
  zephyr,sram = &sram0;
  zephyr,flash = &flash0;
  zephyr,canbus = &can1;
 };

 leds: leds {
  compatible = "gpio-leds";

  green_led: led_0 {
   gpios = <&gpiob 3 (0 << 0)>;
   label = "User LD3";
  };
 };

 aliases {
  led0 = &green_led;
 };
};

&clk_lsi {
 status = "okay";
};

&clk_hsi {
 status = "okay";
};

&pll {
 div-m = <1>;
 mul-n = <20>;
 div-p = <7>;
 div-q = <2>;
 div-r = <4>;
 clocks = <&clk_hsi>;
 status = "okay";
};

&rcc {
 clocks = <&pll>;
 clock-frequency = <(((80) * 1000) * 1000)>;
 ahb-prescaler = <1>;
 apb1-prescaler = <1>;
 apb2-prescaler = <1>;
};

&usart1 {
 pinctrl-0 = <&usart1_tx_pa9 &usart1_rx_pa10>;
 pinctrl-names = "default";
 current-speed = <115200>;
};

&usart2 {
 pinctrl-0 = <&usart2_tx_pa2 &usart2_rx_pa15>;
 pinctrl-names = "default";
 current-speed = <115200>;
 status = "okay";
};

&spi1 {
 pinctrl-0 = <&spi1_nss_pa4 &spi1_sck_pa5
       &spi1_miso_pa6 &spi1_mosi_pa7>;
 pinctrl-names = "default";
 status = "okay";
};

&i2c1 {
 pinctrl-0 = <&i2c1_scl_pb6 &i2c1_sda_pb7>;
 pinctrl-names = "default";
 clock-frequency = <400000>;
 status = "okay";
};

&timers2 {
 status = "okay";

 pwm2: pwm {
  status = "okay";
  pinctrl-0 = <&tim2_ch1_pa0>;
  pinctrl-names = "default";
 };
};

&can1 {
 pinctrl-0 = <&can1_rx_pa11 &can1_tx_pa12>;
 pinctrl-names = "default";
 status = "okay";
};

&rtc {
 clocks = <&rcc (0x058) (1 << 28)>,
   <&rcc 0x003 ((((0x90) & 0xFFFFU) << 0U) | (((8) & 0x1FU) << 16U) | ((((9) - (8)) & 0x3U) << 21U) | ((((2)) & 0xFFU) << 24U))>;
 status = "okay";
};

&flash0 {
 partitions {
  compatible = "fixed-partitions";
  #address-cells = <1>;
  #size-cells = <1>;




  storage_partition: partition@3c000 {
   label = "storage";
   reg = <0x0003c000 ((16) * 1024)>;
  };
 };
};
# 0 "<command-line>" 2
# 1 "C:/Users/kostas.caplinskas/Documents/zephyrproject/miri-tl6-inside-lift/app/boards/nucleo_l432kc.overlay" 1



/ {
};

&spi1 {
    status = "okay";


    pinctrl-0 = <&spi1_nss_pa4 &spi1_sck_pa5
                 &spi1_miso_pa6 &spi1_mosi_pa7>;
    pinctrl-names = "default";


    cs-gpios = <&gpioa 4 (1 << 0)>;

    ads1220: ads1220@0 {
        compatible = "ti,ads1220";
        reg = <0>;
        spi-max-frequency = <1000000>;


        drdy-gpios = <&gpiob 4 (1 << 0)>;

        #io-channel-cells = <1>;
        #address-cells = <1>;
        #size-cells = <0>;

        channel@0 {
            reg = <0>;
            zephyr,gain = "ADC_GAIN_1";
            zephyr,reference = "ADC_REF_INTERNAL";
            zephyr,acquisition-time = <0>;
        };
    };
};
