# 14 "/Users/kostascaplinskas/miri-tl-inside-lift/zephyr/boards/st/nucleo_l073rz/nucleo_l073rz.dts" 2

/ {
 model = "STMicroelectronics STM32L073RZ-NUCLEO board";
 compatible = "st,stm32l073rz-nucleo";

 chosen {
  zephyr,console = &usart2;
  zephyr,shell-uart = &usart2;
  zephyr,sram = &sram0;
  zephyr,flash = &flash0;
 };

 leds: leds {
  compatible = "gpio-leds";

  green_led_2: led_2 {
   gpios = <&gpioa 5 (0 << 0)>;
   label = "User LD2";
  };
 };

 gpio_keys {
  compatible = "gpio-keys";

  user_button: button {
   label = "User";
   gpios = <&gpioc 13 (1 << 0)>;
   zephyr,code = <11>;
  };
 };

 pwmleds: pwmleds {
  compatible = "pwm-leds";

  status = "disabled";

  green_pwm_led: green_pwm_led {
   pwms = <&pwm2 1 (((20) * 1000UL) * 1000UL) (0 << 0)>;
  };
 };

 aliases {
  led0 = &green_led_2;
  sw0 = &user_button;
  pwm-led0 = &green_pwm_led;
  watchdog0 = &iwdg;
  eeprom-0 = &eeprom;
  die-temp0 = &die_temp;
  volt-sensor0 = &vref;
 };
};

&clk_hse {
 hse-bypass;
 clock-frequency = <(((8) * 1000) * 1000)>;
 status = "okay";
};

&clk_lsi {
 status = "okay";
};

&clk_hsi48 {
 status = "okay";
};

&pll {
 div = <2>;
 mul = <8>;
 clocks = <&clk_hse>;
 status = "okay";
};

&rcc {
 clocks = <&pll>;
 clock-frequency = <(((32) * 1000) * 1000)>;
 ahb-prescaler = <1>;
 apb1-prescaler = <1>;
 apb2-prescaler = <1>;
};

stm32_lp_tick_source: &lptim1 {




 clocks = <&rcc (0x038) (1 << 31)>,
   <&rcc 0x003 ((((0x4C) & 0xFFFFU) << 0U) | (((18) & 0x1FU) << 16U) | ((((19) - (18)) & 0x3U) << 21U) | ((((1)) & 0xFFU) << 24U))>;
 status = "okay";
};

&usart1 {
 pinctrl-0 = <&usart1_tx_pb6 &usart1_rx_pb7>;
 pinctrl-names = "default";
 current-speed = <115200>;
};

&usart2 {
 pinctrl-0 = <&usart2_tx_pa2 &usart2_rx_pa3>;
 pinctrl-names = "default";
 current-speed = <115200>;
 status = "okay";
};

&i2c1 {
 pinctrl-0 = <&i2c1_scl_pb8 &i2c1_sda_pb9>;
 pinctrl-names = "default";
 status = "okay";
 clock-frequency = <400000>;
};

&i2c2 {
 pinctrl-0 = <&i2c2_scl_pb10 &i2c2_sda_pb11>;
 pinctrl-names = "default";
 status = "okay";
 clock-frequency = <400000>;
};

&spi1 {
 pinctrl-0 = <&spi1_sck_pa5 &spi1_miso_pa6 &spi1_mosi_pa7>;
 pinctrl-names = "default";
 status = "okay";
};

&iwdg {
 status = "okay";
};

&adc1 {
 pinctrl-0 = <&adc_in0_pa0>;
 pinctrl-names = "default";
 st,adc-clock-source = "SYNC";
 st,adc-prescaler = <4>;
 status = "okay";
};

&die_temp {
 status = "okay";
};

&dac1 {
 status = "okay";
 pinctrl-0 = <&dac_out1_pa4>;
 pinctrl-names = "default";
};

&timers2 {
 st,prescaler = <10000>;
 status = "okay";

 pwm2: pwm {

  pinctrl-0 = <&tim2_ch1_pa5>;
  pinctrl-names = "default";
 };
};

&rtc {
 clocks = <&rcc (0x038) (1 << 28)>,
   <&rcc 0x003 ((((0x50) & 0xFFFFU) << 0U) | (((16) & 0x1FU) << 16U) | ((((17) - (16)) & 0x3U) << 21U) | ((((2)) & 0xFFU) << 24U))>;
 status = "okay";
};

&rng {
 status = "okay";
};

&eeprom {
 status = "okay";
};

&vref {
 status = "okay";
};
